# SAcare 對帳工具 本機設定範本
# 複製成 .env 後填入(或直接執行 setup.command 自動產生)。.env 不會上傳 GitHub。

# EPB WebService 位址 (向主管索取，內含門市內網 IP，勿放公開處)
EPB_WSDL_URL=http://192.168.x.x:8080/EPB_AP_EPB/EPB_AP?wsdl

# EPBReportQuery.java 所在資料夾 (通常=本專案資料夾)
EPB_LIVE_REPORT_ROOT=/path/to/sacare-check

# Java 8 路徑 (setup.command 會自動偵測)
EPB_JAVA=/Library/Java/JavaVirtualMachines/jdk1.8.x/Contents/Home/bin/java
EPB_JAVAC=/Library/Java/JavaVirtualMachines/jdk1.8.x/Contents/Home/bin/javac

# classpath (含 EPBrowser shell.jar)
EPB_JAVA_CP=/path/to/sacare-check:/Library/EPBrowser/EPB/Shell/lib/*:/Library/EPBrowser/EPB/Shell/shell.jar
